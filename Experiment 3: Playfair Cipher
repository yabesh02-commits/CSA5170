#define SIZE 5
char matrix[SIZE][SIZE];
void generateMatrix(char* key) {
int alpha[26] = {0};
int i, j, k = 0;
alpha[&#39;j&#39; - &#39;a&#39;] = 1;
for (i = 0; key[i]; i++) {
char ch = tolower(key[i]);
if (ch == &#39;j&#39;) ch = &#39;i&#39;;
if (isalpha(ch) &amp;&amp; !alpha[ch - &#39;a&#39;]) {
matrix[k / SIZE][k % SIZE] = ch;
alpha[ch - &#39;a&#39;] = 1;
k++;
}
}
for (i = 0; i &lt; 26; i++) {
if (!alpha[i]) {
matrix[k / SIZE][k % SIZE] = i + &#39;a&#39;;
